# ===== DATABASE CONFIGURATION =====
# For local development with H2: Leave these unset or use defaults below
# For MySQL/Production: Set DATABASE_URL or discrete MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD

# Option 1: Combined DATABASE_URL (Railway style)
DATABASE_URL=jdbc:mysql://localhost:3306/citizen_connect?useSSL=false&serverTimezone=UTC

# Option 2: Discrete MySQL variables
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=citizen_connect
MYSQLUSER=root
MYSQLPASSWORD=

# ===== EMAIL CONFIGURATION =====
# Required for OTP (One-Time Password) functionality
# Generate App Password: https://myaccount.google.com/apppasswords (after enabling 2-Step Verification)

MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-character-app-password

# ===== SERVER CONFIGURATION =====
# Port to run the application on
PORT=8080

# ===== SPRING PROFILES =====
# Use 'local' for H2 database (development)
# Leave empty or use 'prod' for MySQL (production)
SPRING_PROFILES_ACTIVE=local

# ===== LOGGING CONFIGURATION =====
# Set to 'true' for debugging SQL queries and OTP codes
SHOW_SQL=false
FORMAT_SQL=false
MAIL_DEBUG=false

# ===== OTP CONFIGURATION =====
# OTP validity in minutes
OTP_EXPIRY_MINUTES=10

# Cooldown between OTP requests in seconds (0 to disable)
OTP_RESEND_COOLDOWN_SECONDS=60

# Print OTP to console logs (DEV ONLY - never use in production)
MAIL_LOG_OTP_TO_CONSOLE=false

# ===== JPA/HIBERNATE CONFIGURATION =====
# DDL strategy: create-drop (recreate each startup), create (only if missing), update (alter tables), validate (no changes), none
# Use 'update' for development, 'validate' for production with migrations
JPA_DDL_AUTO=update

# ===== JWT CONFIGURATION =====
# Token expiration (currently hardcoded to 24 hours in JwtUtil.java)
# Review: src/main/java/com/citizenconnect/security/JwtUtil.java

# ===== RAILWAY/CLOUD DEPLOYMENT =====
# Set automatically by Railway; no need to configure manually
RAILWAY_ENVIRONMENT=production

# ===== DEBUG LOGGING =====
# Uncomment for detailed debugging
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG
# LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG
